# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=info
API_V1_PREFIX=/api/v1
# JSON array; production frontend on Vercel (backend uses this when ENVIRONMENT=production)
ALLOWED_ORIGINS=["http://localhost:5173","https://chem-tutor-frontend.vercel.app"]

# ── Database ───────────────────────────────────────────────────
# Use Neon (prod/dev) or a local Postgres URL
DATABASE_URL=postgresql+asyncpg://chem_user:chem_pass@localhost:5433/chem_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── AI Providers ───────────────────────────────────────────────
# DEFAULT: powerful model — problem generation, reference cards, error classification
DEFAULT_AI_PROVIDER=openai           # openai | anthropic | gemini | mistral

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# FAST: lightweight model — validation, hints, exit tickets
FAST_AI_PROVIDER=openai              # openai | anthropic | gemini | mistral
FAST_OPENAI_MODEL=gpt-5.4-mini
FAST_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
FAST_GEMINI_MODEL=gemini-2.0-flash-lite
FAST_MISTRAL_MODEL=mistral-small-latest

# ── Mastery ────────────────────────────────────────────────────
MASTERY_WINDOW=5                     # Rolling window (last N attempts)
MASTERY_PASSING_SCORE=0.6            # Min attempt score to count toward band-fill
L2_MASTERY_CEILING=0.60              # Top of L2 band (lesson unlocks L3 here)
L3_MASTERY_CEILING=0.85              # Lesson complete / should_advance threshold
L2_ATTEMPTS_TO_FILL=3               # Qualifying attempts to fill L2 band
L3_ATTEMPTS_TO_FILL=3               # Qualifying attempts to fill L3 band

# ── Playlist caps ──────────────────────────────────────────────
L1_MAX_PROBLEMS=3                    # Max worked examples per (user/unit/lesson/level)
L2_MAX_PROBLEMS=5                    # Max faded-practice problems
L3_MAX_PROBLEMS=5                    # Max challenge problems

# ── Auth ───────────────────────────────────────────────────────
# Auth is handled by Supabase JWT on the frontend.
# Set SUPABASE_JWT_SECRET to verify tokens server-side.
SUPABASE_JWT_SECRET=
# Legacy JWT (unused in production — kept for local dev convenience)
JWT_SECRET_KEY=chemtutor-dev-secret-change-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
