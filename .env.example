# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chem_user:chem_pass@localhost:5433/chem_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── AI Providers ──────────────────────────────────────────────
# DEFAULT: powerful model — used for problem generation (use openai if Gemini fails)
DEFAULT_AI_PROVIDER=openai         # openai | anthropic | gemini

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# FAST: lightweight model — used for validation and hints
FAST_AI_PROVIDER=openai            # openai | anthropic | gemini
FAST_OPENAI_MODEL=gpt-4o-mini
FAST_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
FAST_GEMINI_MODEL=gemini-2.0-flash-lite

# ── Mastery ───────────────────────────────────────────────────
MASTERY_THRESHOLD=0.75             # 75% to advance (also Level 3 unlock threshold)
MASTERY_WINDOW=5                   # Last N attempts for rolling average

# ── Problem Cache ──────────────────────────────────────────────
CACHE_MIN_PER_SLOT=3               # Min Level 1 worked examples per cache slot
CACHE_L2_L3_TTL_DAYS=7            # Days before Level 2/3 cache entries expire

# ── Security ──────────────────────────────────────────────────
# AUTH is handled by Supabase JWT on the frontend.
# Set this to your Supabase JWT secret for server-side verification.
SUPABASE_JWT_SECRET=
