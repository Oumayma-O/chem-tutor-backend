        "unit_id":      "VARCHAR(100) FK → units.id",
        "lesson_id":    "VARCHAR(100) FK → lessons.id  (lessons gets a new slug PK)",
        "lesson_order": "INTEGER — ordering within this unit",
        "is_ap_only":   "BOOLEAN — hide from Standard view even if lesson is in this unit"
      },
      "primary_key": ["unit_id", "lesson_id"]
    },
    "lessons_table_changes": {
      "add_column": "slug VARCHAR(100) UNIQUE NOT NULL  (e.g. 'L-molar-mass-1step')",
      "keep_column": "chapter_id / unit_id — used for the canonical Standard unit assignment",
      "note": "lesson_id in unit_lessons references lessons.slug, not lessons.id (integer)"
    },
    "units_table_changes": {
      "note": "No structural change. course_id still points to Standard Chemistry or AP Chemistry course row."
    }
  },

  "frontend_filter_logic": {
    "standard_user": "Show units WHERE course_id = standard_course.id (16 units). In each unit, show lessons WHERE is_ap_only = false.",
    "ap_user":       "Show units WHERE course_id = ap_course.id (9 units). Show ALL lessons including is_ap_only = true."
  }
}
